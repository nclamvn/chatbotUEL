# ── PLACEHOLDER BÀN GIAO ────────────────────────────────────────────
# Phía Trường điền key qua secret manager hoặc biến môi trường triển khai.
# Không ghi key thật vào source code, README, ảnh chụp hoặc commit Git.
# OpenAI là provider chính; Anthropic tự động tiếp quản khi OpenAI lỗi.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model theo provider
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_MODEL=claude-sonnet-4-6

# hash: embedder tất định offline (pilot) · e5: multilingual-e5-small qua fastembed
EMBEDDINGS=hash

# PLACEHOLDER: thay bằng secret riêng trên production.
POSTGRES_PASSWORD=tkt

# Cổng HTTP của Caddy trên host (production dùng 80)
HTTP_PORT=8080

# Cổng Postgres publish ra host (đổi khi 5433 đã bị dự án khác chiếm)
DB_HOST_PORT=5433

# Domain production để Caddy tự lo TLS, vd: tkt-bot.example.edu.vn
SITE_ADDRESS=

# CORS: danh sách origin cho phép gọi API cross-origin, phẩy ngăn cách.
# Bỏ trống thì suy từ SITE_ADDRESS (https://<host>); vẫn trống nghĩa là cấm
# mọi cross-origin, an toàn vì web và api chung origin sau Caddy.
# Dev gọi API trực tiếp thì khai, vd: http://localhost:3002,http://localhost:3000
CORS_ORIGINS=

# Giới hạn độ dài câu hỏi, quá thì trả 422 kèm gợi ý rút gọn
MAX_QUESTION_LEN=500

# ── TIP-13 staging ──
# Chế độ bàn giao mặc định: template = chỉ Demo, không gọi API.
# Chỉ đổi thành llm sau khi đã cấu hình ít nhất một API key hợp lệ.
MODE=template
# Banner thử nghiệm + noindex: 1 bật (staging), 0 tắt (production). Build ARG của web.
NEXT_PUBLIC_STAGING=1
# Gate mời (basic auth web). Bỏ trống = mở (dev/local).
STAGING_USER=
STAGING_PASS=
# Basic auth riêng cho trang /admin (telemetry). Bỏ trống = admin luôn 401.
ADMIN_USER=
ADMIN_PASS=
