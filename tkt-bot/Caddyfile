# SITE_ADDRESS: domain production (vd tkt.uel.example), compose cấp mặc định :80.
{$SITE_ADDRESS} {
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:8000
	}

	# TIP-13: trang admin telemetry, api tự lo basic auth riêng
	handle /admin* {
		reverse_proxy api:8000
	}

	handle {
		reverse_proxy web:3000
	}
}
